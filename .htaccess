Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route all app requests through /public without hardcoded project names.
    RewriteRule ^$ public/ [L]
    RewriteCond %{REQUEST_URI} !/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
