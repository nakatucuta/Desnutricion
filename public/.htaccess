<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    #RewriteBase /rutasintegrales/

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Production subdirectory entrypoint fallback.
    RewriteCond %{REQUEST_URI} ^/rutasintegrales/?$
    RewriteRule ^$ /rutasintegrales/login [L,R=302]

    # Ensure the application root URL resolves through Laravel front controller.
    RewriteRule ^$ index.php [L]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_setenvif.c>
    # Vite assets are content-hashed, safe for immutable long-term caching.
    SetEnvIfNoCase Request_URI "^/rutasintegrales/build/assets/" IS_VITE_ASSET=1
</IfModule>

<IfModule mod_headers.c>
    Header append Vary Accept-Encoding
    Header set Cache-Control "public, max-age=31536000, immutable" env=IS_VITE_ASSET
</IfModule>

<IfModule mod_deflate.c>
    <FilesMatch "\\.(?:txt|html?|xml|css|js|json|svg)$">
        SetOutputFilter DEFLATE
    </FilesMatch>
    SetEnvIfNoCase Request_URI "\\.(?:gif|jpe?g|png|webp|avif|ico|woff2?|ttf|otf|eot|zip|gz|mp4|mp3)$" no-gzip
</IfModule>
