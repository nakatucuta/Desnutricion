#!/usr/bin/env sh

if [ "$1" != "rebase" ]; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)" || exit 1

echo "[hook] post-rewrite(rebase): ejecutando deploy_production_safe..."
ARGS=""
if [ "${DEPLOY_HOOK_DRY_RUN:-0}" = "1" ]; then
  ARGS="$ARGS -DryRun"
fi

if [ "${DEPLOY_HOOK_RESTART_APACHE:-0}" = "1" ]; then
  ARGS="$ARGS -RestartApache"
fi

CHANGED_FILES="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null)"
if [ -z "$CHANGED_FILES" ]; then
  CHANGED_FILES="$(git diff --name-only HEAD@{1} HEAD 2>/dev/null)"
fi

if ! printf "%s\n" "$CHANGED_FILES" | grep -Eq '^(composer\.json|composer\.lock)$'; then
  ARGS="$ARGS -SkipComposer"
fi

if ! printf "%s\n" "$CHANGED_FILES" | grep -Eq '^database/migrations/'; then
  ARGS="$ARGS -SkipMigrate"
fi

echo "[hook] argumentos deploy:$ARGS"
powershell -ExecutionPolicy Bypass -File scripts/deploy_production_safe.ps1 $ARGS
status=$?

if [ "$status" -ne 0 ]; then
  echo "[hook] ERROR: deploy_production_safe.ps1 fallo con codigo $status"
  exit $status
fi

echo "[hook] post-rewrite: deploy completado."
exit 0
